# =============================================================================
# PokerTools Production Environment
#
# Copy to .env.production and fill in your values:
#   cp .env.production.example .env.production
#
# Generate strong secrets with: openssl rand -base64 32
# =============================================================================

# ---- Application ----
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=https://your-domain.example.com
METRICS_TOKEN=
ALLOWED_SIWE_CHAIN_IDS=1,31337
DEFAULT_CURRENCY=USDC
SESSION_TTL_SECONDS=604800
RATE_LIMIT_MAX=100
AUTH_NONCE_RATE_LIMIT_MAX=5
AUTH_LOGIN_RATE_LIMIT_MAX=10
MAX_WITHDRAWAL_AMOUNT_CENTS=1000000
TABLE_REDIS_TTL_SECONDS=86400
TABLE_LOCK_TTL_MS=10000
ACTION_TIMEOUT_SECONDS=30
DEPOSIT_MONITOR_INTERVAL_MS=15000
RECONCILIATION_INTERVAL_MS=300000
TOURNAMENT_BLIND_INTERVAL_MS=900000
TOURNAMENT_BLIND_SCAN_INTERVAL_MS=15000
# Externalised operational constants (defaults match prior hardcoded values).
INITIAL_SCAN_LOOKBACK_BLOCKS=100
DEPOSIT_SCAN_CONCURRENCY=5
DEPOSIT_SCAN_MAX_RPCS=10
DEPOSIT_SCAN_LIMIT_DURATION_MS=1000
SETTLE_HAND_LOCK_TTL_MS=5000
NEXT_HAND_LOCK_TTL_MS=3000
REDLOCK_RETRY_COUNT=3
REDLOCK_RETRY_DELAY_MS=100
REDLOCK_DRIFT_FACTOR=0.01
RECONCILIATION_WINDOW_HOURS=24
RECONCILIATION_BATCH_SIZE=100
AUTO_DEAL_DELAY_MS=5000
WITHDRAWAL_MESSAGE_TTL_MS=300000
NONCE_TTL_SECONDS=300
RETRY_TRANSIENT_ATTEMPTS=10
RETRY_TRANSIENT_BACKOFF_BASE_MS=100
TABLE_LISTING_PAGE_SIZE=50
IDEMPOTENCY_TTL_SECONDS=3600
TOURNAMENT_LOCK_TTL_MS=30000
TOURNAMENT_LISTING_PAGE_SIZE=100
MAX_TOURNAMENT_TABLES=10
WS_MAX_CONNECTIONS_PER_USER=4
WS_MAX_PRE_AUTH_QUEUE=8
WS_HEARTBEAT_INTERVAL_MS=30000
RISK_SCORE_THRESHOLD=70
RISK_WITHDRAW_USER_LIMIT=5
RISK_BUY_IN_USER_LIMIT=12
RISK_ACTION_USER_LIMIT=60
RISK_WITHDRAW_IP_LIMIT=20
RISK_BUY_IN_IP_LIMIT=40
RISK_ACTION_IP_LIMIT=200

# ---- PostgreSQL ----
POSTGRES_USER=pokertools
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_DB=pokertools
# Full connection string used by the API and migrations.
# The hostname "postgres" resolves to the compose service on the internal network.
DATABASE_URL=postgresql://pokertools:CHANGE_THIS_TO_A_STRONG_PASSWORD@postgres:5432/pokertools

# ---- Redis ----
# The hostname "redis" resolves to the compose service on the internal network.
# REDIS_PASSWORD must match the --requirepass value configured on the redis
# service in docker-compose.prod.yml. Generate with: openssl rand -base64 32
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ---- Security secrets (REQUIRED — generate with openssl rand -base64 32) ----
JWT_SECRET=
COOKIE_SECRET=
WALLET_ENCRYPTION_SECRET=
# Encrypts HD wallet extended private key material. Required for
# the admin service (sweeper/withdrawals). Generate independently from
# WALLET_ENCRYPTION_SECRET with:  openssl rand -base64 32
WALLET_XPRIV_ENCRYPTION_SECRET=
PBKDF2_ITERATIONS=600000

# ---- Caddy / TLS ----
# Public domain that Caddy will obtain a Let's Encrypt certificate for.
CADDY_DOMAIN=api.your-domain.example.com
# Email for Let's Encrypt expiry notifications.
CADDY_ACME_EMAIL=ops@your-domain.example.com

# ---- Admin Service (sweeper, withdrawal bot, monitors) ----
# BIP-39 mnemonic for the HD hot wallet (12 or 24 words).
# Can also be loaded from a Docker secret file via MASTER_MNEMONIC_FILE.
MASTER_MNEMONIC=
# BIP-44 derivation path for the hot wallet account (default shown).
HOT_WALLET_DERIVATION_PATH=m/44'/60'/0'/0/0
# Deployed BatchSweeper contract addresses per chain.
BATCH_SWEEPER_ADDRESS_MAINNET=
BATCH_SWEEPER_ADDRESS_POLYGON=
BATCH_SWEEPER_ADDRESS_LOCAL=
# Optional JSON override, e.g. {"1":"0x...","8453":"0x..."}
SWEEPER_CONTRACT_MAP=
# Telegram bot token (from @BotFather) and admin chat ID for approvals.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ---- Admin Operational Thresholds ----
MAX_GAS_PRICE_GWEI=50
MIN_SWEEP_VALUE_RAW_UNITS=10
LOW_GAS_THRESHOLD_ETH=0.1
MAX_SINGLE_WITHDRAWAL_USD=5000
MAX_DAILY_WITHDRAWAL_USD=50000

# ---- Admin RPC Resilience ----
RPC_RETRY_COUNT=3
RPC_RETRY_DELAY_MS=1000
RPC_TIMEOUT_MS=10000
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_OPEN_MS=30000
WITHDRAWAL_SIGNATURE_MAX_AGE_MS=300000
WITHDRAWAL_POLL_INTERVAL_MS=3000
RECOVERY_SCAN_INTERVAL_MS=300000
TRANSACTION_MONITOR_INTERVAL_MS=60000
SWEEP_INTERVAL_MS=600000
GAS_MONITOR_INTERVAL_MS=1800000
STUCK_WITHDRAWAL_MAX_AGE_MS=21600000

# ---- Automated Backups ----
# Interval between backup runs in seconds (default 86400 = every 24 hours).
BACKUP_INTERVAL=86400
# Number of days to keep backup files (default 7).
BACKUP_RETENTION_DAYS=7

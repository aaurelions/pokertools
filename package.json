{
  "name": "pokertools-monorepo",
  "version": "1.0.10",
  "private": true,
  "description": "Enterprise-grade Texas Hold'em poker engine and API monorepo",
  "author": "A.Aurelius",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aaurelions/pokertools.git"
  },
  "bugs": {
    "url": "https://github.com/aaurelions/pokertools/issues"
  },
  "homepage": "https://github.com/aaurelions/pokertools#readme",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "npm install",
    "build": "npm run build --workspaces --if-present",
    "build:watch": "tsc -b --watch",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "test": "npm run test --workspaces --if-present",
    "test:quick": "npm run test --workspace @pokertools/engine -- --silent && npm run test --workspace @pokertools/evaluator -- --silent && npm run test --workspace @pokertools/types -- --silent && npm run test --workspace @pokertools/sdk -- --reporter=dot",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "lint": "eslint . --ext .ts --max-warnings 30",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "typecheck": "tsc -b",
    "validate": "npm run format:check && npm run lint && npm test",
    "precommit": "npm run format:check && npm run lint && npm run test:quick",
    "prepare": "git config core.hooksPath .githooks && npm run db:generate:prepare -w @pokertools/api --if-present && tsc -b",
    "dev:api": "npm run dev -w @pokertools/api",
    "dev:workers": "npm run workers -w @pokertools/api",
    "start:api": "npm start -w @pokertools/api",
    "bench": "npm run bench -w @pokertools/bench",
    "redis": "redis-server",
    "db:migrate": "npm run db:migrate -w @pokertools/api",
    "db:seed": "npm run db:seed -w @pokertools/api",
    "db:studio": "npm run db:studio -w @pokertools/api",
    "db:reset": "npm run db:reset -w @pokertools/api",
    "ci": "npm run clean && npm run setup && npm run test",
    "e2e:docker": "npm run test:docker -w @pokertools/e2e"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "fast-check": "^4.8.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "prettier-plugin-solidity": "^2.3.1",
    "prisma": "^7.8.0",
    "react-dom": "^19.2.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "esbuild": "^0.28.1",
    "tsup": {
      "esbuild": "^0.28.1"
    },
    "ws": "^8.21.0",
    "viem@2.53.1": {
      "ws": "^8.21.0"
    },
    "js-yaml": "^5.1.0",
    "test-exclude": "^7.0.1"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "@swc/core@1.15.43": true,
    "esbuild@0.27.0": true,
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true,
    "microtime@3.1.1": true,
    "msgpackr-extract@3.0.4": true,
    "prisma@7.8.0": true,
    "unrs-resolver@1.12.2": true,
    "better-sqlite3@12.11.1": true
  }
}

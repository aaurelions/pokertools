{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "composite": false,
    "types": ["node"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["tests/**/*", "../api/generated/**/*", "../api/src/utils/**/*", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}

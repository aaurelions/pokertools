{
  "name": "@pokertools/admin",
  "version": "1.0.8",
  "description": "Fund aggregation (sweeper) and withdrawal processing service",
  "author": "A.Aurelius",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist coverage cache node_modules contracts/out",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "contracts:build": "forge build",
    "contracts:test": "forge test",
    "db:prepare": "npm run db:ensure:test --workspace=@pokertools/api",
    "pretest": "npm run contracts:build && npm run db:prepare",
    "test": "vitest run tests/e2e/full-lifecycle.test.ts",
    "test:stand-alone": "npm run infra:up --workspace=@pokertools/api && npm run test; npm run infra:down --workspace=@pokertools/api",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "keywords": [
    "poker",
    "admin",
    "blockchain",
    "sweeper",
    "withdrawal",
    "telegram"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@pokertools/types": "1.0.8",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "envalid": "^8.2.0",
    "grammy": "^1.44.0",
    "ioredis": "^5.11.1",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "viem": "^2.53.1"
  }
}
